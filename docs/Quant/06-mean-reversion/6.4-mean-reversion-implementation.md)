# 6.4 Python实现：均值回归策略回测

## 完整回测框架

```python
class MeanReversionBacktester:
    """均值回归策略回测框架"""
    
    def __init__(self, tickers, start, end):
        self.tickers = tickers
        self.start = start
        self.end = end
        self.data = None
        self.signals = None
        self.returns = None
        
    def load_data(self):
        """加载数据"""
        self.data = yf.download(self.tickers, start=self.start, 
                                  end=self.end)['Close']
        self.data.columns = self.data.columns.get_level_values(0)
        return self
    
    def run_bollinger_strategy(self, window=20, num_std=2):
        """布林带策略"""
        signals = pd.DataFrame(0, index=self.data.index, columns=self.data.columns)
        
        for ticker in self.data.columns:
            prices = self.data[ticker]
            bb = bollinger_bands(prices, window, num_std)
            
            # 触及下轨买入
            signals.loc[prices < bb['lower'], ticker] = 1
            # 触及上轨卖出
            signals.loc[prices > bb['upper'], ticker] = -1
        
        signals = signals.shift(1).fillna(0)
        self.signals = signals
        return self
    
    def run_rsi_strategy(self, period=14, buy=30, sell=70):
        """RSI策略"""
        signals = pd.DataFrame(0, index=self.data.index, columns=self.data.columns)
        
        for ticker in self.data.columns:
            prices = self.data[ticker]
            rsi = calculate_rsi(prices, period)
            
            signals.loc[rsi < buy, ticker] = 1
            signals.loc[rsi > sell, ticker] = -1
        
        signals = signals.shift(1).fillna(0)
        self.signals = signals
        return self
    
    def run_backtest(self):
        """运行回测"""
        returns = self.data.pct_change()
        # 等权策略
        strategy_returns = (self.signals * returns).mean(axis=1)
        # 只保留有持仓的时期
        holding = self.signals.abs().sum(axis=1) > 0
        self.returns = strategy_returns[holding]
        return self
    
    def performance(self):
        """计算绩效"""
        total = (1 + self.returns).prod() - 1
        annual = self.returns.mean() * 252
        vol = self.returns.std() * np.sqrt(252)
        sharpe = annual / vol if vol > 0 else 0
        maxdd = ((1 + self.returns).cumprod() / 
                 (1 + self.returns).cumprod().cummax()).min() - 1
        win_rate = (self.returns > 0).mean()
        
        print(f"\n{'='*50}")
        print(f"均值回归策略回测结果")
        print(f"{'='*50}")
        print(f"总收益: {total:.2%}")
        print(f"年化收益: {annual:.2%}")
        print(f"夏普比率: {sharpe:.2f}")
        print(f"最大回撤: {maxdd:.2%}")
        print(f"胜率: {win_rate:.2%}")
        
        return {
            'total_return': total,
            'annual_return': annual,
            'sharpe': sharpe,
            'max_drawdown': maxdd,
            'win_rate': win_rate
        }

# 使用示例
backtester = MeanReversionBacktester(['AAPL', 'MSFT'], '2022-01-01', '2023-12-31')
backtester.load_data().run_bollinger_strategy().run_backtest().performance()
```

